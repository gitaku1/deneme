import dataiku

# 1. Adımda bulduğunuz veya bildiğiniz LLM ID'sini buraya yazın
# Örn: "openai:my-connection:gpt-4"
LLM_ID = "SENIN_LLM_ID_BURAYA" 

client = dataiku.api_client()
project = client.get_default_project()

# LLM objesini al
llm = project.get_llm(LLM_ID)

# Yeni bir tamamlama (completion) sorgusu oluştur
completion = llm.new_completion()

# Mesajınızı ekleyin
completion.with_message("Dataiku LLM Mesh hakkında kısa bir özet yapabilir misin?")

# Sorguyu çalıştır
response = completion.execute()

# Sonucu yazdır
if response.success:
    print(response.text)
else:
    print("Bir hata oluştu:", response.error_message)
