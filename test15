from openai import OpenAI

# ==============================
# SADECE BURAYI DEĞİŞTİR
# ==============================

CUSTOM_URL = "http://host:port/v1"   # Dataiku connection içindeki customURL (sonu /v1 olacak)
API_KEY = "sk-xxxx"                  # Dataiku connection içindeki apiKey
MODEL_NAME = "model_adi"             # Kullanacağın model adı

# ==============================
# KODUN DEVAMI
# ==============================

client = OpenAI(
    api_key=API_KEY,
    base_url=CUSTOM_URL
)

try:
    response = client.chat.completions.create(
        model=MODEL_NAME,
        messages=[
            {"role": "system", "content": "You are a helpful assistant."},
            {"role": "user", "content": "Explain Docker simply."}
        ],
        temperature=0.7,
        max_tokens=300
    )

    print("=== MODEL RESPONSE ===")
    print(response.choices[0].message.content)

except Exception as e:
    print("HATA OLUŞTU:")
    print(e)
