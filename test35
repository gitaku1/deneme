import requests
from datetime import datetime

# --- USER CONFIGURATION ---
ARTIFACTORY_URL = "https://artifactroyaddress:443/artifactory"
REPOSITORY_NAME = "imagelar"  # Your repository name
USER = "user"
PASSWORD = "pass"
# --------------------------

def get_detailed_image_tags():
    base_url = ARTIFACTORY_URL.rstrip('/')
    repo_url = f"{base_url}/api/storage/{REPOSITORY_NAME}"
    
    headers = {
        "Accept": "application/json"
    }
    
    print("Connecting to Artifactory Storage API...")
    print(f"Scanning Repository: {REPOSITORY_NAME}\n")
    
    try:
        # 1. Fetch main image folders
        response = requests.get(repo_url, auth=(USER, PASSWORD), headers=headers, verify=False)
        response.raise_for_status()
        root_data = response.json()
        
        images = root_data.get("children", [])
        
        if not images:
            print("No images found in this repository.")
            return

        # We will collect all data first to calculate maximum widths dynamically
        all_data = []
        max_img_len = len("IMAGE NAME")
        max_tag_len = len("TAG / VERSION")
        
        print("Gathering image and tag details from Artifactory (Dynamic sizing enabled)...")
        
        for img in images:
            if not img.get("folder", False):
                continue
                
            img_name = img.get("uri", "").lstrip('/')
            img_url = f"{repo_url}/{img_name}"
            
            # Update max image length for layout
            if len(img_name) > max_img_len:
                max_img_len = len(img_name)
                
            img_response = requests.get(img_url, auth=(USER, PASSWORD), headers=headers, verify=False)
            if img_response.status_code != 200:
                all_data.append({"image": img_name, "tag": "[Error fetching tags]", "date": "-"})
                continue
                
            img_data = img_response.json()
            tags = img_data.get("children", [])
            
            if not tags:
                all_data.append({"image": img_name, "tag": "[No tags found]", "date": "-"})
                continue
            
            image_tags_list = []
            for tag in tags:
                if not tag.get("folder", False):
                    continue
                    
                tag_name = tag.get("uri", "").lstrip('/')
                tag_url = f"{img_url}/{tag_name}"
                
                if len(tag_name) > max_tag_len:
                    max_tag_len = len(tag_name)
                    
                tag_response = requests.get(tag_url, auth=(USER, PASSWORD), headers=headers, verify=False)
                
                date_str = "Unknown"
                if tag_response.status_code == 200:
                    tag_data = tag_response.json()
                    raw_date = tag_data.get("lastModified", tag_data.get("created", "Unknown"))
                    
                    if raw_date != "Unknown":
                        try:
                            clean_date_str = raw_date.split('.')[0].replace('Z', '').replace('T', ' ')
                            dt = datetime.strptime(clean_date_str, "%Y-%m-%d %H:%M:%S")
                            date_str = dt.strftime("%Y-%m-%d %H:%M:%S")
                        except Exception:
                            date_str = raw_date
                            
                image_tags_list.append({"tag": tag_name, "date": date_str})
                
            all_data.append({"image": img_name, "tags": image_tags_list})

        # Padding spaces
        padding = 3
        img_width = max_img_len + padding
        tag_width = max_tag_len + padding
        date_width = 20
        
        total_width = img_width + tag_width + date_width + 6 # 6 accounts for ' | ' separators
        
        # 2. Print the perfectly aligned dynamic table
        print("\n" + "=" * total_width)
        print(f"{'IMAGE NAME':<{img_width}} | {'TAG / VERSION':<{tag_width}} | {'CREATION DATE':<{date_width}}")
        print("=" * total_width)
        
        for item in all_data:
            img_name = item["image"]
            
            # If there was an error or no tags found
            if "tag" in item:
                print(f"{img_name:<{img_width}} | {item['tag']:<{tag_width}} | {item['date']:<{date_width}}")
                print("-" * total_width)
                continue
                
            first_row = True
            for t_info in item["tags"]:
                if first_row:
                    print(f"{img_name:<{img_width}} | {t_info['tag']:<{tag_width}} | {t_info['date']:<{date_width}}")
                    first_row = False
                else:
                    print(f"{'':<{img_width}} | {t_info['tag']:<{tag_width}} | {t_info['date']:<{date_width}}")
            
            print("-" * total_width)

    except requests.exceptions.HTTPError as e:
        print("\nHTTP Error Occurred!")
        print(f"Status Code: {e.response.status_code}")
    except requests.exceptions.RequestException as e:
        print(f"\nConnection Error: {e}")

if __name__ == "__main__":
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    
    get_detailed_image_tags()
