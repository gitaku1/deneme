#!/bin/bash

# =========================================================================
# YAPILANDIRMA: "CONFIG_PATH:MANUEL_NAMESPACE"
# - Eğer namespace kısmını boş bırakırsan (: işaretinden sonrası), namespace'i 
#   otomatik olarak config dosyasının içinden okumaya çalışır.
# =========================================================================
CONFIG_MAP=(
    "$HOME/.kube/config-prod:"                # Namespace'i dosyanın içinden otomatik bulur
    "$HOME/.kube/config-dev:custom-ns-name"   # Namespace dosya adından farklı, manuel yazıldı
    "$HOME/.kube/config-test:"                # Namespace'i dosyanın içinden otomatik bulur
)

# Eğer dosyanın içinden de namespace okunamazsa kullanılacak son çare varsayılanı:
DEFAULT_FALLBACK_NS="default"
# =========================================================================

echo "=================================================================="
echo "Config Dosyaları ve Namespace Analizi Başladı..."
echo "=================================================================="

for item in "${CONFIG_MAP[@]}"; do
    # İki nokta işaretine göre ayır
    config_path="${item%%:*}"
    namespace="${item#*:}"

    # Dosya kontrolü
    if [ ! -f "$config_path" ]; then
        echo -e "\n\033[1;31m[HATA]\033[0m Dosya bulunamadı: $config_path"
        continue
    fi

    # Kubeconfig export et
    export KUBECONFIG="$config_path"

    # Eğer manuel namespace girilmediyse, dosyanın içinden bulmayı dene
    if [ -z "$namespace" ]; then
        # Mevcut context'in namespace bilgisini config içinden çeker
        current_context=$(oc config current-context 2>/dev/null)
        namespace=$(oc config view -o jsonpath="{.contexts[?(@.name=='$current_context')].context.namespace}" 2>/dev/null)
        
        # Eğer config içinde de tanımlı bir namespace yoksa fallback değerine geç
        if [ -z "$namespace" ]; then
            namespace=$DEFAULT_FALLBACK_NS
        fi
    fi

    # 'oc project' ile ilgili namespace'e geçiş yap
    if ! oc project "$namespace" > /dev/null 2>&1; then
        echo -e "\n\033[1;31m[HATA]\033[0m '$namespace' namespace'ine geçilemedi. (Config: $config_path)"
        continue
    fi

    # 2 günden eski podları filtrele
    old_pods=$(oc get pods --no-headers 2>/dev/null | awk '$5 ~ /[2-9][0-9]*d|[1-9][0-9]{1,}d/ {print $1, $5}')

    if [ ! -z "$old_pods" ]; then
        echo -e "\n\033[1;34m[Config Dosyası]\033[0m: $config_path"
        echo -e "\033[1;32m[Namespace]\033[0m     : $namespace"
        echo "------------------------------------------------------------------"
        printf "%-55s %-10s\n" "Pod Adı" "Yaşı"
        echo "------------------------------------------------------------------"
        
        while read -r pod_info; do
            pod_name=$(echo $pod_info | awk '{print $1}')
            pod_age=$(echo $pod_info | awk '{print $2}')
            printf "%-55s %-10s\n" "$pod_name" "$pod_age"
        done <<< "$old_pods"
        echo "=================================================================="
    fi
done
