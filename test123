from tabulate import tabulate

# 1. Listeni bu üç tırnak arasına doğrudan yapıştır.
# Satır ne kadar uzun veya kaç kelime olursa olsun fark etmez.
elindeki_ham_metin = """
Bilgisayar A 16 Core 1.2 TB
Ana Sunucu Merkez Ofis 32 Core 2.4 TB
Yedek PC 8 Core 500 GB
Canavar Oyun Bilgisayari 64 Core 4.0 TB
"""

# 2. Sütun başlıkların
basliklar = ["Cihaz Adı", "İşlemci", "Depolama"]

veri_listesi = []

# Satır satır oku
for satir in elindeki_ham_metin.strip().split("\n"):
    satir = satir.strip()
    if not satir:
        continue
    
    # Satırı tüm boşluklardan kelime kelime ayır
    kelimeler = satir.split()
    
    if len(kelimeler) >= 5:  # En az: İsim (1) + Miktar (1) + Core (1) + Miktar (1) + TB/GB (1) = 5 kelime olmalı
        # 1. En sondaki iki kelime depolamadır (örn: 1.2, TB) -> Boşluksuz birleştir
        depolama = kelimeler[-2] + kelimeler[-1]
        
        # 2. Ondan önceki iki kelime işlemcidir (örn: 16, Core) -> Boşluksuz birleştir
        islemci = kelimeler[-4] + kelimeler[-3]
        
        # 3. Geriye kalan en baştaki tüm kelimeler cihazın adıdır -> Boşluksuz birleştir
        cihaz_adi_kelimeleri = kelimeler[:-4]
        cihaz_adi = "".join(cihaz_adi_kelimeleri)
        
        # Tam 3 sütun olarak listeye ekle
        veri_listesi.append([cihaz_adi, islemci, depolama])

# Tabloyu oluştur (Çizgili grid formatında)
tablo = tabulate(veri_listesi, headers=basliklar, tablefmt="grid")

print(tablo)
