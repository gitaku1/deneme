import requests
from datetime import datetime

# --- USER CONFIGURATION ---
ARTIFACTORY_URL = "https://artifactroyaddress:443/artifactory"
REPOSITORY_NAME = "imagelar"  # Your repository name
USER = "user"
PASSWORD = "pass"
# --------------------------

def get_images_via_storage_api():
    base_url = ARTIFACTORY_URL.rstrip('/')
    # Standard Storage API endpoint for directory listing
    url = f"{base_url}/api/storage/{REPOSITORY_NAME}"
    
    headers = {
        "Accept": "application/json"
    }
    
    print(f"Fetching repository structure from: {url}\n")
    
    try:
        response = requests.get(
            url, 
            auth=(USER, PASSWORD), 
            headers=headers,
            verify=False
        )
        
        response.raise_for_status()
        data = response.json()
        
        # Get all children (files/folders) in the root of the repository
        children = data.get("children", [])
        
        if not children:
            print("No images found in this repository.")
            return

        print(f"{'IMAGE / FOLDER':<45} | {'CREATION / MODIFIED DATE':<20}")
        print("-" * 70)
        
        for child in children:
            child_uri = child.get("uri", "")
            is_folder = child.get("folder", False)
            
            # If it's a folder, it represents an image or a tag directory
            if child_uri:
                # Remove leading slash if exists
                clean_name = child_uri.lstrip('/')
                
                # Fetch detailed metadata for this specific item to get its timestamp
                detail_url = f"{url}{child_uri}"
                detail_resp = requests.get(detail_url, auth=(USER, PASSWORD), headers=headers, verify=False)
                
                date_str = "Unknown"
                if detail_resp.status_code == 200:
                    detail_data = detail_resp.json()
                    # Fallback chain for dates: lastModified -> created
                    date_str = detail_data.get("lastModified", detail_data.get("created", "Unknown"))
                    
                    if date_str != "Unknown":
                        try:
                            # Format date nicely
                            dt = datetime.fromisoformat(date_str.replace("Z", "+00:00"))
                            date_str = dt.strftime("%Y-%m-%d %H:%M:%S")
                        except ValueError:
                            pass
                
                print(f"{clean_name:<45} | {date_str:<20}")

    except requests.exceptions.HTTPError as e:
        print("HTTP Error Occurred!")
        print(f"Status Code: {e.response.status_code}")
        print(f"Response Text:\n{e.response.text}")
    except requests.exceptions.RequestException as e:
        print(f"Connection Error: {e}")

if __name__ == "__main__":
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    
    get_images_via_storage_api()
