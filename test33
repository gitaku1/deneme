import requests
import json
from datetime import datetime

# --- USER CONFIGURATION ---
# If you face URL issues, try changing this to just "https://artifactroyaddress:443"
ARTIFACTORY_URL = "https://artifactroyaddress:443/artifactory"
REPOSITORY_NAME = "imagelar"  # Your repository name
USER = "user"
PASSWORD = "pass"
# --------------------------

def get_artifactory_images():
    # 1. Cleaning trailing slashes and building the secure AQL endpoint
    base_url = ARTIFACTORY_URL.rstrip('/')
    url = f"{base_url}/api/search/aql"
    
    # 2. Stable AQL query to find folders (images and tags)
    aql_query = f'items.find({{"repo": "{REPOSITORY_NAME}", "type": "folder"}}).include("name", "path", "created")'
    
    # 3. Mandatory headers to prevent Artifactory from throwing 400 Bad Request
    headers = {
        "Content-Type": "text/plain",
        "Accept": "application/json"
    }
    
    print(f"Sending request to: {url}")
    print(f"Target Repository: {REPOSITORY_NAME}\n")

    try:
        response = requests.post(
            url, 
            auth=(USER, PASSWORD), 
            data=aql_query, 
            headers=headers,
            verify=False  # Disables SSL verification (like curl -k)
        )
        
        # Throws an exception if status code is 400, 401, 500 etc.
        response.raise_for_status()
        
        results = response.json().get("results", [])
        
        if not results:
            print("No images or folders found in this repository.")
            return

        # Printing the result table with clean headers
        print(f"{'IMAGE (PATH)':<40} | {'TAG / FOLDER':<25} | {'CREATION DATE':<20}")
        print("-" * 91)
        
        for item in results:
            path = item.get("path", "")
            name = item.get("name", "")
            
            # Skip root folders or empty paths
            if path == ".":
                continue
                
            created_date = item.get("created", "")
            if created_date:
                try:
                    # Formatting the ISO timestamp for better readability
                    dt = datetime.fromisoformat(created_date.replace("Z", "+00:00"))
                    created_date = dt.strftime("%Y-%m-%d %H:%M:%S")
                except ValueError:
                    pass # Keep raw format if parsing fails

            print(f"{path:<40} | {name:<25} | {created_date:<20}")

    except requests.exceptions.HTTPError as e:
        print("HTTP Error Occurred!")
        print(f"Status Code: {e.response.status_code}")
        print(f"Artifactory Error Message:\n{e.response.text}")
    except requests.exceptions.RequestException as e:
        print(f"Connection Error: {e}")

if __name__ == "__main__":
    # Disables warning clutter due to verify=False
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    
    get_artifactory_images()
