import requests
import json
from datetime import datetime

# --- USER CONFIGURATION ---
ARTIFACTORY_URL = "https://artifactroyaddress:443/artifactory"
REPOSITORY_NAME = "imagelar"  # Your repository name
USER = "user"
PASSWORD = "pass"
# --------------------------

def get_artifactory_images():
    base_url = ARTIFACTORY_URL.rstrip('/')
    url = f"{base_url}/api/search/aql"
    
    # Updated AQL query to strictly include repo, path, and name in the criteria
    # Using "$match": "*" satisfies the permission requirement by checking all paths and names
    aql_query = (
        f'items.find({{'
        f'"repo": "{REPOSITORY_NAME}", '
        f'"path": {{"$match": "*"}}, '
        f'"name": {{"$match": "*"}}'
        f'}}).include("name", "path", "created")'
    )
    
    headers = {
        "Content-Type": "text/plain",
        "Accept": "application/json"
    }
    
    print(f"Sending request to: {url}")
    print(f"Target Repository: {REPOSITORY_NAME}\n")

    try:
        response = requests.post(
            url, 
            auth=(USER, PASSWORD), 
            data=aql_query, 
            headers=headers,
            verify=False
        )
        
        response.raise_for_status()
        results = response.json().get("results", [])
        
        if not results:
            print("No images or folders found in this repository.")
            return

        print(f"{'IMAGE (PATH)':<40} | {'TAG / FILE':<25} | {'CREATION DATE':<20}")
        print("-" * 91)
        
        for item in results:
            path = item.get("path", "")
            name = item.get("name", "")
            
            if path == ".":
                continue
                
            created_date = item.get("created", "")
            if created_date:
                try:
                    dt = datetime.fromisoformat(created_date.replace("Z", "+00:00"))
                    created_date = dt.strftime("%Y-%m-%d %H:%M:%S")
                except ValueError:
                    pass

            print(f"{path:<40} | {name:<25} | {created_date:<20}")

    except requests.exceptions.HTTPError as e:
        print("HTTP Error Occurred!")
        print(f"Status Code: {e.response.status_code}")
        print(f"Artifactory Error Message:\n{e.response.text}")
    except requests.exceptions.RequestException as e:
        print(f"Connection Error: {e}")

if __name__ == "__main__":
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    
    get_artifactory_images()
