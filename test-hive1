export HIVE_CONF_DIR=/veridiski/hive-server/conf
export PATH=$JAVA_HOME/bin:$HADOOP_HOME/bin:$HIVE_HOME/bin:$PATH

source ~/.bash_profile
echo $JAVA_HOME
echo $HADOOP_HOME
echo $HIVE_HOME


find $HADOOP_HOME -name "*aws*"
