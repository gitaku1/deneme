vi ~/.bash_profile

export JAVA_HOME=/usr/lib/jvm/java-17-openjdk-17.0.17
export HADOOP_HOME=/opt/hadoop-3.3.4
export HADOOP_CONF_DIR=/veridiski/hive-server/conf
