import sys
import os

# 1. Adım: Temel Import Testi
try:
    import docling
    from docling.document_converter import DocumentConverter
    from docling.datamodel.base_models import InputFormat
    from docling.datamodel.pipeline_options import PdfPipelineOptions
    print(f"✅ Docling başarıyla import edildi. Versiyon: {docling.__version__}")
except ImportError as e:
    print(f"❌ Kütüphane bulunamadı: {e}")
    print(f"Şu anki Python Yolu (Executable): {sys.executable}")
    # Eğer burada hata alıyorsan pip install "docling[all]" komutunu tekrar kontrol etmeliyiz.
    sys.exit()

# 2. Adım: Extraction (Çıkarım) Motorunu Hazırlama
try:
    # Reçete arka planda bu converter'ı kullanır
    pipeline_options = PdfPipelineOptions()
    pipeline_options.do_ocr = True  # OCR gerekip gerekmediğini test eder
    
    converter = DocumentConverter()
    print("✅ DocumentConverter (Motor) başarıyla başlatıldı.")
except Exception as e:
    print(f"❌ Motor başlatılamadı (Bağımlılık hatası olabilir): {e}")
    sys.exit()

# 3. Adım: Gerçek Dosya Testi (Hata aldığın .docx veya .pdf dosyasının yolunu buraya yaz)
# Örnek: "/data/managed_folder/test.docx"
test_file_path = "BURAYA_DOSYA_YOLUNU_YAZ.docx" 

if os.path.exists(test_file_path):
    try:
        print(f"🔄 {test_file_path} işleniyor...")
        result = converter.convert(test_file_path)
        
        # İçeriği kontrol et
        content = result.document.export_to_markdown()
        print("✅ Dosya başarıyla okundu!")
        print("-" * 30)
        print(f"İlk 200 karakter:\n{content[:200]}")
        print("-" * 30)
    except Exception as e:
        print(f"❌ Dosya işlenirken hata oluştu: {e}")
else:
    print(f"⚠️ Test dosyası bulunamadı: {test_file_path}. Lütfen yolu kontrol et.")
