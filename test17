import sys
import subprocess
import pkgutil

print("Python executable:", sys.executable)
print("Python version:", sys.version)

# 1️⃣ Docling paketinin yüklü olup olmadığını kontrol et
import importlib.util
docling_spec = importlib.util.find_spec("docling")
docling_core_spec = importlib.util.find_spec("docling_core")

print("docling found:", docling_spec)
print("docling_core found:", docling_core_spec)

# 2️⃣ Docling içindeki modülleri listele
if docling_spec:
    import docling
    print("docling path:", docling.__file__)
    if hasattr(docling, "__path__"):
        print("docling modules:", [m.name for m in pkgutil.iter_modules(docling.__path__)])

if docling_core_spec:
    import docling_core
    print("docling_core path:", docling_core.__file__)
    if hasattr(docling_core, "__path__"):
        print("docling_core modules:", [m.name for m in pkgutil.iter_modules(docling_core.__path__)])

# 3️⃣ Subprocess ile Structured Extraction importunu test et (recipe’de patlayan kısım)
print("\nTesting import in subprocess (simulates recipe kernel)...")
cmd = [
    sys.executable,
    "-c",
    "try:\n"
    "    from docling.document import Document\n"
    "    print('docling.document import OK')\n"
    "except Exception as e:\n"
    "    print('docling.document import failed:', e)\n"
    "try:\n"
    "    from docling_core.types.doc.document import Document\n"
    "    print('docling_core Document import OK')\n"
    "except Exception as e:\n"
    "    print('docling_core Document import failed:', e)\n"
]

result = subprocess.run(cmd, capture_output=True, text=True)
print("Return code:", result.returncode)
print("STDOUT:\n", result.stdout)
print("STDERR:\n", result.stderr)
