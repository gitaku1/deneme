import dataiku

client = dataiku.api_client()
project = client.get_default_project()

# Projedeki TÜM modelleri al
all_llms = project.list_llms()

print("--- Bulunan Embedding Modelleri ---")
embedding_model_ids = []

for m in all_llms:
    # Modelin ham verisindeki yeteneklere (capabilities) bakıyoruz
    raw_data = m.get_settings().get_raw()
    capabilities = raw_data.get("capabilities", {})
    
    # Eğer 'embeddings' yeteneği True ise listeye ekle
    if capabilities.get("embeddings") is True:
        print(f"Model ID: {m.id}")
        embedding_model_ids.append(m.id)

if not embedding_model_ids:
    print("Uyarı: Projede aktif embedding modeli bulunamadı. Lütfen Project Settings > LLM Mesh kısmını kontrol edin.")




# Listeden bulduğunuz Embedding destekli ID'yi buraya yazın
EMBEDDING_MODEL_ID = "openai:senin-baglantin:text-embedding-3-small" 

llm = project.get_llm(EMBEDDING_MODEL_ID)

# Tek bir metin veya liste gönderebilirsiniz
test_text = "Dataiku üzerinde embedding testi yapıyorum."

# .embed() metodu LLM Mesh üzerinden vektörü döndürür
vector = llm.embed(test_text)

print(f"Vektör başarıyla oluşturuldu. Boyut: {len(vector[0])}")
print(f"İlk 3 sayı: {vector[0][:3]}")
