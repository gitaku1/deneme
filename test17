import dataiku

# 1. Dataiku API Client başlatılıyor
client = dataiku.api_client()

# 2. Tüm bağlantıları çekiyoruz
all_connections = client.list_connections()

print("--- Dataiku OpenAI Bağlantıları ve Embedding Modelleri Taraması ---\n")

found_any = False

for conn_name, conn_info in all_connections.items():
    # Sadece OpenAI tipindeki bağlantıları filtreliyoruz
    # Not: Dataiku versiyonuna göre 'type' 'openai' veya 'openai-llm' olabilir
    if conn_info.get('type') in ['openai', 'openai-llm']:
        found_any = True
        print(f"Bağlantı Bulundu: [{conn_name}]")
        
        try:
            # Bağlantı detaylarını al
            connection = client.get_connection(conn_name)
            # Modelleri 'details' içinden veya direkt 'info'dan çekmeyi dene
            details = connection.get_info().get("details", {})
            models = details.get("models", [])
            
            embedding_models = []
            for m in models:
                # Hem yeteneklere (capabilities) bakıyoruz hem de isme
                capabilities = m.get('capabilities', [])
                model_id = m.get('id', '').lower()
                
                if 'embedding' in capabilities or 'embed' in model_id:
                    embedding_models.append(m.get('id'))
            
            if embedding_models:
                for em in embedding_models:
                    print(f"  -> Model: {em}")
            else:
                print("  ! Bu bağlantıda embedding özellikli model tanımlanmamış.")
                
        except Exception as e:
            print(f"  X Bağlantı detayları alınamadı: {str(e)}")
        print("-" * 40)

if not found_any:
    print("Sistemde OpenAI tipinde herhangi bir bağlantı bulunamadı.")


