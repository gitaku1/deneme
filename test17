import dataiku

client = dataiku.api_client()
project = client.get_default_project()

# Embeddings modellerini ayrıca listeliyoruz
embeddings_models = project.list_embeddings_models()

print("--- Kayıtlı Embedding Modelleri ---")
for model in embeddings_models:
    # model nesnesi üzerinden ID ve detayları alalım
    print(f"Model ID: {model.id}")
    # İçeriğini merak ederseniz:
    # print(vars(model))




# Listeden bulduğunuz Embedding destekli ID'yi buraya yazın
EMBEDDING_MODEL_ID = "openai:senin-baglantin:text-embedding-3-small" 

llm = project.get_llm(EMBEDDING_MODEL_ID)

# Tek bir metin veya liste gönderebilirsiniz
test_text = "Dataiku üzerinde embedding testi yapıyorum."

# .embed() metodu LLM Mesh üzerinden vektörü döndürür
vector = llm.embed(test_text)

print(f"Vektör başarıyla oluşturuldu. Boyut: {len(vector[0])}")
print(f"İlk 3 sayı: {vector[0][:3]}")
