import dataiku
from dataikuapi.dss.llm import DSSLLM

# Bağlantı ve model ID'nizi girin
llm_id = "openai:baglanti_isminiz:gpt-4o"
client = dataiku.api_client()
project = client.get_default_project()
llm = project.get_llm(llm_id)

# Test mesajı gönderin
completion = llm.new_completion()
completion.with_message("Buraya test etmek istediğiniz mesajı yazın")

try:
    response = completion.execute()
    print("Cevap:", response.text)
except Exception as e:
    print("Hata (Muhtemelen Moderasyon Tarafından Engellendi):", e)
