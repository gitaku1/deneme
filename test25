#!/usr/bin/env python3
import os
import subprocess
import json
from datetime import datetime, timezone

# =========================================================================
# CONFIGURATION: Just set the top-level directory path here.
# The script will recursively search all files inside this directory and its subdirectories.
# =========================================================================
BASE_KUBE_DIR = os.path.expanduser("~/.kube")
DEFAULT_FALLBACK_NS = "default"
# =========================================================================

def run_command_with_errors(command):
    """Executes a shell command. Prints stderr if the command fails."""
    result = subprocess.run(command, shell=True, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"  \033[1;33m[DEBUG CLI ERROR]\033[0m Command failed: '{command}'")
        print(f"  \033[1;33m[Reason]\033[0m: {result.stderr.strip()}")
        return None
    return result.stdout.strip()

def get_namespace_from_config():
    """Extracts the default namespace of the current active context from the kubeconfig."""
    current_ctx = run_command_with_errors("oc config current-context")
    if not current_ctx:
        return None
        
    config_json_str = run_command_with_errors("oc config view -o json")
    if not config_json_str:
        return None
    
    try:
        config_data = json.loads(config_json_str)
        for ctx_item in config_data.get("contexts", []):
            if ctx_item.get("name") == current_ctx:
                return ctx_item.get("context", {}).get("namespace")
    except Exception as e:
        print(f"  \033[1;33m[DEBUG JSON ERROR]\033[0m Parsing failed: {e}")
        return None
    return None

def find_all_files_recursively(base_dir):
    """Recursively finds all files in the given directory and its subdirectories."""
    file_list = []
    if not os.path.exists(base_dir):
        print(f"\033[1;31m[ERROR]\033[0m Base directory does not exist: {base_dir}")
        return file_list

    for root, dirs, files in os.walk(base_dir):
        for file in files:
            # Skip hidden files or temporary terminal files (like .kube/cache)
            if file.startswith('.') or 'cache' in root or 'http-cache' in root:
                continue
            full_path = os.path.join(root, file)
            file_list.append(full_path)
    return file_list

def main():
    print("==================================================================")
    print("DEBUG MODE: Recursive Kubeconfig & Namespace Auto-Discovery Tool")
    print("==================================================================\n")
    
    now = datetime.now(timezone.utc)
    
    # Step 1: Discover all files under the base directory recursively
    print(f"Scanning directory recursively: {BASE_KUBE_DIR}")
    all_configs = find_all_files_recursively(BASE_KUBE_DIR)
    print(f"Found {len(all_configs)} potential config files to analyze.\n")

    for config_path in all_configs:
        print(f"Analyzing file: {config_path}")
        
        # Step 2: Dynamically export KUBECONFIG for the current file
        os.environ["KUBECONFIG"] = config_path

        # Step 3: Automatically discover namespace inside this specific file
        namespace = get_namespace_from_config()
        if not namespace:
            print(f"  Auto-discovery failed for this file. Falling back to: {DEFAULT_FALLBACK_NS}")
            namespace = DEFAULT_FALLBACK_NS
        else:
            print(f"  Discovered active namespace from file: {namespace}")

        # Step 4: Validate context/project switch
        print(f"  Testing connection and switching to: oc project {namespace}")
        if run_command_with_errors(f"oc project {namespace}") is None:
            print(f"  \033[1;31m[ERROR]\033[0m Skipping file due to connection or missing cluster permissions.\n")
            print("=" * 70)
            continue

        # Step 5: Fetch live pod data
        print(f"  Fetching live pods...")
        pods_output = run_command_with_errors(f"oc get pods -n {namespace} -o json")
        if not pods_output:
            print(f"  \033[1;31m[ERROR]\033[0m Could not retrieve pod list for this target.\n")
            print("=" * 70)
            continue

        try:
            pods_data = json.loads(pods_output).get("items", [])
        except Exception as e:
            print(f"  \033[1;31m[ERROR]\033[0m JSON parsing error for pods: {e}\n")
            print("=" * 70)
            continue

        print(f"  Total pods found in cluster: {len(pods_data)}")
        
        has_printed_header = False
        old_pods_counter = 0

        # Step 6: Filter and calculate age
        for pod in pods_data:
            pod_name = pod["metadata"]["name"]
            status = pod.get("status", {})
            start_time_str = status.get("startTime")
            
            if not start_time_str:
                continue
                
            start_time = datetime.strptime(start_time_str, "%Y-%m-%dT%H:%M:%SZ").replace(tzinfo=timezone.utc)
            age_days = (now - start_time).days

            # Filters pods strictly older than 2 days
            if age_days >= 2:
                old_pods_counter += 1
                if not has_printed_header:
                    print(f"\n\033[1;34m[Config Path]\033[0m: {config_path}")
                    print(f"\033[1;32m[Namespace]\033[0m  : {namespace}")
                    print("-" * 70)
                    print(f"{'Pod Name':<50} | {'Age':<15}")
                    print("-" * 70)
                    has_printed_header = True
                
                print(f"{pod_name:<50} | {age_days} days")
        
        print(f"\n  [DEBUG SUMMARY]: Found {old_pods_counter} pods older than 2 days in this targeting layer.")
        print("=" * 70 + "\n")

if __name__ == "__main__":
    main()
