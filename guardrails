  "meta": {
    "label": "Toxicity Guardrail",
    "description": "Checks prompts using external Toxic-BERT endpoint"
  },

  "operatesOnQueries": true,
  "operatesOnResponses": false,

  "mayRequestRetryOnResponses": false,
  "mayRespondDirectlyToQueries": true,

  "params": [

    {
      "name": "endpoint",
      "label": "Toxicity API endpoint",
      "type": "STRING",
      "defaultValue": "http://HOST:PORT/classify"
    },

    {
      "name": "threshold",
      "label": "Toxicity threshold",
      "type": "DOUBLE",
      "defaultValue": 0.7
    }

  ]
}












import requests
import logging
from dataiku.llm.guardrails import BaseGuardrail


class Guardrail(BaseGuardrail):

    def set_config(self, config, plugin_config):

        self.endpoint = config.get("endpoint")
        self.threshold = config.get("threshold", 0.7)


    def check_toxicity(self, text):

        payload = {
            "inputs": text
        }

        r = requests.post(self.endpoint, json=payload, timeout=5)

        r.raise_for_status()

        result = r.json()

        if isinstance(result, list):
            result = result[0]

        label = result.get("label")
        score = result.get("score")

        return label, score


    def process(self, input, trace):

        logging.info("Running Toxicity Guardrail")

        if "completionQuery" in input:

            prompt = input["completionQuery"]["messages"][0]["content"]

            label, score = self.check_toxicity(prompt)

            logging.info(f"Toxicity result: {label} {score}")

            if score and score > self.threshold:

                return {
                    "response": {
                        "text": "Your request was blocked because it contains toxic content."
                    }
                }

        return input








