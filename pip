import os
import subprocess
import sys
import json

# Temel arama dizinleri
SEARCH_DIRS = [
    "/usr/bin",
    "/usr/local/bin",
    "/opt",
    "/usr/sbin",
    "/usr/local/sbin"
]

def find_all_python_binaries():
    """Sistemdeki benzersiz ve gecerli Python binary dosyalarini bulur."""
    binaries = set()
    
    # Mevcut calisan Python'i ekle
    binaries.add(os.path.realpath(sys.executable))
    
    # 3.6 ile 3.12 arasindaki surumlerin hedef isimleri
    target_versions = ["3.6", "3.7", "3.8", "3.9", "3.10", "3.11", "3.12", "3"]
    target_names = ["python" + ver for ver in target_versions] + ["python"]
    
    for base_dir in SEARCH_DIRS:
        if not os.path.exists(base_dir):
            continue
            
        # Alt dizinleri derinlemesine tara
        for root, dirs, files in os.walk(base_dir):
            # Cok derin dizinlere inerek vakit kaybetmeyi onle
            if root.count(os.sep) - base_dir.count(os.sep) > 3:
                continue
                
            for file in files:
                if file in target_names:
                    full_path = os.path.join(root, file)
                    # Dosyanin calistirilabilir ve gercek bir dosya oldugunu kontrol et
                    if os.path.isfile(full_path) and os.access(full_path, os.X_OK):
                        real_path = os.path.realpath(full_path)
                        binaries.add(real_path)
                        
    return sorted(list(binaries))

def get_packages_safely(python_bin):
    """Her Python surumu icin en uygun yontemle site-packages ve paketleri bulur."""
    # pkg_resources hatasini cozmek icin dinamik fallback mekanizmasi iceren inline script
    inline_script = """
import sys
import json
import site

# 1. site-packages yollarini tespit et
try:
    paths = site.getsitepackages()
except AttributeError:
    try:
        from distutils.sysconfig import get_python_lib
        paths = [get_python_lib()]
    except ImportError:
        paths = sys.path

packages = {}

# 2. Modern Python'lar icin importlib.metadata dene (Python 3.8+)
try:
    import importlib.metadata as meta
    for dist in meta.distributions():
        packages[dist.metadata['Name']] = dist.version
except ImportError:
    # 3. Eski Python'lar icin pkg_resources dene (Python 3.6 - 3.7)
    try:
        import pkg_resources
        for dist in pkg_resources.working_set:
            packages[dist.project_name] = dist.version
    except ImportError:
        # 4. O da yoksa fallback olarak pip list komutunu dene
        try:
            import subprocess
            res = subprocess.run([sys.executable, "-m", "pip", "list", "--format=json"], capture_output=True, text=True)
            if res.returncode == 0:
                pip_data = json.loads(res.stdout)
                for item in pip_data:
                    packages[item['name']] = item['version']
        except Exception:
            pass

print(json.dumps({"paths": paths, "packages": packages}))
"""
    try:
        result = subprocess.run(
            [python_bin, "-c", inline_script],
            capture_output=True,
            text=True,
            timeout=20
        )
        if result.returncode == 0:
            return json.loads(result.stdout.strip())
    except Exception:
        pass
    return None

def main():
    print("=" * 80)
    print(" Linux Python Environment & site-packages Scanner ".center(80, "#"))
    print("=" * 80)
    print("[*] Python binary dosyalari araniyor (3.6 - 3.12)...")
    
    binaries = find_all_python_binaries()
    
    if not binaries:
        print("[-] Hicbir Python kurulumu tespit edilemedi.")
        return

    print(f"[+] Toplam {len(binaries)} adet benzersiz Python kurulumu bulundu.\n")

    for py_bin in binaries:
        # Detayli versiyon bilgisini ogren
        try:
            ver_res = subprocess.run([py_bin, "--version"], capture_output=True, text=True)
            py_version = ver_res.stdout.strip() if ver_res.stdout else ver_res.stderr.strip()
        except Exception:
            py_version = "Bilinmeyen Versiyon"

        print(f"🚀 PYTHON YOLU   : {py_bin}")
        print(f"   VERSION       : {py_version}")
        
        data = get_packages_safely(py_bin)
        
        if not data:
            print("   ⚠️  Hata: Paket bilgileri ve site-packages yollari okunamadi.")
            print("-" * 80)
            continue
            
        print("   SITE-PACKAGES :")
        for path in data["paths"]:
            if path.strip():
                print(f"     └─ {path}")
            
        print("\n   KURULU PAKETLER VE VERSIYONLARI:")
        packages = data["packages"]
        if not packages:
            print("     (Bu ortamda ucuncu parti paket bulunamadi veya pip eksik)")
        else:
            # Hizalanmis tablo yapisi
            print(f"     {'Paket Adi'.ljust(40)} | {'Versiyon'.ljust(20)}")
            print(f"     {'-'*40}-+-{'-'*20}")
            for pkg_name, pkg_ver in sorted(packages.items()):
                print(f"     {pkg_name.ljust(40)} | {pkg_ver.ljust(20)}")
                
        print("\n" + "=" * 80)

if __name__ == "__main__":
    main()
